# ===========================================
# ARTE Chatbot - Environment Variables
# ===========================================
# Copy this file to .env for local development only.
# Do not commit real secrets. Production receives secrets from AWS Secrets
# Manager or SSM and uses IAM roles/default credential chains.

# --- App runtime ---
# local | staging | production. Production requires explicit non-wildcard CORS.
APP_ENV=local
LOG_LEVEL=INFO
PORT=8000

# Public URLs used by deployed/runtime clients.
DOMAIN_NAME=artesolutions.com.co
PUBLIC_API_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:3000
PUBLIC_ADMIN_URL=http://localhost:3000
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# --- OpenAI ---
# Required locally and in deployed runtime; deploy via Secrets Manager/SSM in ECS.
OPENAI_API_KEY=your_openai_api_key_here

# Optional. Model identifier for LLM interactions. Default: gpt-5.4-nano
LLM_MODEL=gpt-5.4-nano

# --- Auth ---
# Required. API key for authenticating clients of the /chat endpoint.
# Generate locally with:
# echo CHAT_API_KEY=$(openssl rand -base64 32) >> .env
CHAT_API_KEY=

# --- AWS S3 ---
# Local development may use explicit keys, AWS_PROFILE, or any AWS default
# credential-chain source. ECS production must use the task role, not static keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

# Bucket and region. Production Terraform currently defaults to arte-chatbot-fichas-tecnicas.
AWS_BUCKET_NAME=arte-chatbot-fichas-tecnicas
AWS_REGION=us-east-2

# --- CI/CD and Terraform inputs (do not put GitHub secrets here) ---
# GitHub Actions uses OIDC via AWS_ROLE_ARN and repository variables for ECR URLs.
# Local staging consumes explicit immutable ECR tags only.
BACKEND_IMAGE_TAG=sha-your_commit_sha
FRONTEND_IMAGE_TAG=sha-your_commit_sha
ADMIN_IMAGE_TAG=sha-your_commit_sha

# Local staging example values; use staging-specific secrets, params, and buckets.
STAGING_ID=pr-123
STAGING_EXPIRES_AT=2026-06-05T12:00:00Z
STAGING_AWS_BUCKET_NAME=arte-chatbot-staging-data

# Optional. Persist /chat conversation turns to S3 for the admin Logs screen.
# docker compose defaults this to true for local admin-panel runs unless explicitly set.
CONVERSATION_LOGGING_ENABLED=true
CONVERSATION_LOG_PREFIX=conversations

# --- WhatsApp Conversational Features ---
# All flags default to false (zero-risk deployment). Enable individually.
WHATSAPP_FORMATTER_ENABLED=false
SPLIT_MESSAGES_ENABLED=false
MSG_DELAY_MIN_MS=3000
MSG_DELAY_MAX_MS=5000
GREETING_ENABLED=false
GREETING_TIMEZONE=America/Bogota
MULTI_MESSAGE_BUFFER_ENABLED=false
BUFFER_WINDOW_SECONDS=5

# --- Evaluation Harness (optional, only for running evaluation) ---
API_BASE_URL=http://localhost:8000
DATASET_PATH=evaluation/harness/dataset.json
OUTPUT_DIR=evaluation/harness/output
EVAL_S3_PREFIX=evaluation/local/
