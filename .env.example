# OpenAI API Key for the RAG LLM provider
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model for LLM interactions
LLM_MODEL=gpt-5.4-nano

# AWS credentials to access the S3 bucket where technical sheets lives on
# This credentials must be provided by the AWS assignee (currently @creep1ng)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=arte-chatbot-fichas-tecnicas

# API Key for authenticating with the /chat endpoint
# Generate it with openssl:
# echo CHAT_API_KEY=$(openssl rand -base64 32) >> .env
