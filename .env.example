# ===========================================
# ARTE Chatbot - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Validation is automatic via Pydantic Settings.

# --- OpenAI ---
# Required. API key for OpenAI LLM services.
OPENAI_API_KEY=your_openai_api_key_here

# Optional. Model identifier for LLM interactions. Default: gpt-5.4-nano
LLM_MODEL=gpt-5.4-nano

# --- AWS S3 ---
# Required. AWS credentials to access the S3 bucket with technical datasheets.
# These credentials must be provided by the AWS assignee (currently @creep1ng)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional. S3 bucket name. Default: arte-chatbot-fichas-tecnicas
AWS_BUCKET_NAME=arte-chatbot-fichas-tecnicas

# Optional. AWS region. Default: us-east-1
AWS_REGION=us-east-1

# --- Auth ---
# Required. API key for authenticating clients of the /chat endpoint.
# Generate it with openssl:
# echo CHAT_API_KEY=$(openssl rand -base64 32) >> .env
CHAT_API_KEY=

# Required for the admin panel. Separate API key for /admin/* endpoints.
# This key is entered manually in the admin login screen and MUST NOT be
# embedded in the frontend bundle.
# Generate it with openssl:
# echo ADMIN_API_KEY=$(openssl rand -base64 32) >> .env
ADMIN_API_KEY=

# --- App ---
# Optional. Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL. Default: INFO
LOG_LEVEL=INFO

# --- WhatsApp Conversational Features ---
# All flags default to false (zero-risk deployment). Enable individually.
#
# P1: WhatsApp formatting filter (markdown → WhatsApp-native text)
# WHATSAPP_FORMATTER_ENABLED=false
#
# P2: Conversational splitting (enviar_mensajes tool)
# SPLIT_MESSAGES_ENABLED=false
# MSG_DELAY_MIN_MS=3000
# MSG_DELAY_MAX_MS=5000
#
# P3: First-contact greeting
# GREETING_ENABLED=false
# GREETING_TIMEZONE=America/Bogota
#
# P4: Multi-message input buffering
# MULTI_MESSAGE_BUFFER_ENABLED=false
# BUFFER_WINDOW_SECONDS=5

# --- Evaluation Harness (optional, only for running evaluation) ---
# Base URL of the ARTE Chatbot API. Default: http://localhost:8000
API_BASE_URL=http://localhost:8000

# Path to the evaluation dataset JSON file.
DATASET_PATH=evaluation/harness/dataset.json

# Directory to save evaluation results.
OUTPUT_DIR=evaluation/harness/output
